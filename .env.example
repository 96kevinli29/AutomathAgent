# ============================================================
# AutomathAgent Configuration
# ============================================================
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#
# You need API keys for TWO models (can be the same provider).
# Get keys from the provider's website listed below.
# ============================================================

# ── Model 1: Proof Generation ──────────────────────────────
# This model generates Lean4 proofs and translates them to NL.
# Uncomment ONE provider and fill in the key.

# OpenAI      — https://platform.openai.com/api-keys
#MODEL1_PROVIDER=openai
#MODEL1_API_KEY=sk-...
#MODEL1_MODEL=gpt-4o

# Claude      — https://console.anthropic.com/settings/keys
#MODEL1_PROVIDER=claude
#MODEL1_API_KEY=sk-ant-...
#MODEL1_MODEL=claude-sonnet-4-20250514

# DeepSeek    — https://platform.deepseek.com/api_keys
#MODEL1_PROVIDER=deepseek
#MODEL1_API_KEY=sk-...
#MODEL1_MODEL=deepseek-chat

# Qwen        — https://dashscope.console.aliyun.com/apiKey
#MODEL1_PROVIDER=qwen
#MODEL1_API_KEY=sk-...
#MODEL1_MODEL=qwen-plus

# Kimi        — https://platform.moonshot.cn/console/api-keys
#MODEL1_PROVIDER=kimi
#MODEL1_API_KEY=sk-...
#MODEL1_MODEL=kimi-k2.5

# MiniMax     — https://platform.minimaxi.com/user-center/basic-information/interface-key
MODEL1_PROVIDER=minimax
MODEL1_API_KEY=
MODEL1_MODEL=MiniMax-Text-01

# Ollama (local, no key needed)
#MODEL1_PROVIDER=ollama
#MODEL1_API_KEY=ollama
#MODEL1_MODEL=llama3


# ── Model 2: Second Verification ───────────────────────────
# This model reconstructs a proof from NL to verify fidelity.
# Can be the same or different provider as Model 1.

MODEL2_PROVIDER=kimi
MODEL2_API_KEY=
MODEL2_MODEL=kimi-k2.5


# ── Advanced Settings (optional) ───────────────────────────
#CANDIDATES=8
#MAX_REPAIR=3
